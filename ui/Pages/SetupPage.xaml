<Page x:Class="CloudRedirect.Pages.SetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:res="clr-namespace:CloudRedirect.Resources"
      ScrollViewer.CanContentScroll="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="800">
            <TextBlock Text="{res:Loc Setup_Title}"
                       FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,4" />
            <TextBlock x:Name="DescriptionText"
                       Text="{res:Loc Setup_Description}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,16" />

            <!-- Client type selector: pick before deploying -->
            <StackPanel x:Name="ClientTypeSelector" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="RadioSteamTools"
                                 Content="{res:Loc Setup_ClientType_ST}"
                                 GroupName="ClientType"
                                 Margin="0,0,16,0"
                                 Checked="RadioSteamTools_Checked" />
                    <RadioButton x:Name="RadioThirdParty"
                                 GroupName="ClientType"
                                 Checked="RadioThirdParty_Checked" />
                </StackPanel>
                <TextBlock x:Name="ClientTypeWarning"
                           Foreground="#FFAA00"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"
                           Visibility="Collapsed" />
            </StackPanel>

            <ui:Button x:Name="RunAllButton"
                       Content="{res:Loc Setup_RunAllPatches}"
                       Icon="{ui:SymbolIcon FlashCheckmark24}"
                       Appearance="Primary"
                       FontSize="14"
                       Padding="24,10"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,24"
                       IsEnabled="False"
                       Click="RunAll_Click" />

            <TextBlock Text="{res:Loc Setup_LogOutput}"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,8" />

            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,24"
                    MinHeight="200"
                    MaxHeight="400">
                <ScrollViewer x:Name="LogScrollViewer"
                              VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="LogOutput"
                             FontFamily="Cascadia Code,Consolas,Courier New"
                             FontSize="12"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Text="{res:Loc Setup_Ready}" />
                </ScrollViewer>
            </Border>

            <!-- Manifest endpoint override (ST-only) -->
            <StackPanel x:Name="ManifestEndpointSection" Margin="0,0,0,16">
                <TextBlock Text="{res:Loc Setup_ManifestEndpoint}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{res:Loc Setup_ManifestEndpoint_Description}"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <TextBlock Text="Endpoint URL"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4" />
                <ui:TextBox x:Name="ManifestEndpointBox"
                            PlaceholderText="https://example.com/manifest/"
                            Margin="0,0,0,12"
                            LostFocus="ManifestEndpoint_LostFocus" />

                <TextBlock Text="User-Agent"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4" />
                <ui:TextBox x:Name="ManifestUserAgentBox"
                            PlaceholderText="MyClient/1.0"
                            Margin="0,0,0,8"
                            LostFocus="ManifestEndpoint_LostFocus" />
            </StackPanel>

            <!-- Diagnostics toggle -->
            <ui:CardControl Margin="0,0,0,8">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{res:Loc Setup_ShowDiagnostics}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{res:Loc Setup_ShowDiagnosticsHint}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="DiagnosticsToggle"
                                 Checked="DiagnosticsToggle_Click"
                                 Unchecked="DiagnosticsToggle_Click" />
            </ui:CardControl>

            <!-- Collapsible diagnostics panel -->
            <StackPanel x:Name="DiagnosticsPanel" Visibility="Collapsed">

                <ui:CardControl x:Name="VersionCard" Margin="0,8,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{res:Loc Setup_SteamVersion}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="VersionStatusText"
                                       Text="{res:Loc Setup_Checking}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:SymbolIcon x:Name="VersionIcon" Symbol="Info24" FontSize="24" />
                </ui:CardControl>

                <ui:CardControl Margin="0,0,0,16">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{res:Loc Setup_SteamPath}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="SteamPathText"
                                       Text="{res:Loc Setup_Detecting}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:Button Content="{res:Loc Setup_Change}"
                               Icon="{ui:SymbolIcon FolderOpen24}"
                               Click="BrowseSteamDir_Click" />
                </ui:CardControl>

                <!-- ST-only sections (hidden in thirdparty mode) -->
                <StackPanel x:Name="STOnlySection">

                <TextBlock Text="{res:Loc Setup_OfflineSetupHeader}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{res:Loc Setup_OfflineSetupDescription}"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />

                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{res:Loc Setup_OfflineSetup}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="OfflineStatusText"
                                       Text="{res:Loc Setup_NotChecked}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:SymbolIcon Symbol="WifiOff24" FontSize="24" />
                </ui:CardControl>

                <WrapPanel Margin="0,0,0,24">
                    <ui:Button x:Name="OfflineSetupButton"
                               Content="{res:Loc Setup_ApplyOfflineSetup}"
                               Icon="{ui:SymbolIcon WifiOff24}"
                               Appearance="Primary"
                               Margin="0,0,8,0"
                               Click="OfflineSetup_Click" />
                    <ui:Button x:Name="OfflineRevertButton"
                               Content="{res:Loc Setup_RevertPatch}"
                               Icon="{ui:SymbolIcon ArrowUndo24}"
                               Margin="0,0,8,0"
                               Visibility="Collapsed"
                               Click="OfflineRevert_Click" />
                </WrapPanel>

                <TextBlock Text="{res:Loc Setup_StExeHeader}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{res:Loc Setup_StExeDescription}"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />

                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{res:Loc Setup_DllDeploy}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="StExeStatusText"
                                       Text="{res:Loc Setup_NotChecked}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:SymbolIcon Symbol="ShieldTask24" FontSize="24" />
                </ui:CardControl>

                <WrapPanel Margin="0,0,0,24">
                    <ui:Button x:Name="StExePatchButton"
                               Content="{res:Loc Setup_PatchSteamToolsExe}"
                               Icon="{ui:SymbolIcon ShieldTask24}"
                               Margin="0,0,8,0"
                               Click="StExePatch_Click" />
                    <ui:Button x:Name="StExeUnpatchButton"
                               Content="{res:Loc Setup_RevertPatch}"
                               Icon="{ui:SymbolIcon ArrowUndo24}"
                               Margin="0,0,8,0"
                               Visibility="Collapsed"
                               Click="StExeUnpatch_Click" />
                </WrapPanel>

                <TextBlock x:Name="CloudRedirectPatchHeaderText"
                           Text="{res:Loc Setup_CloudRedirectPatchHeader}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,8" />
                <TextBlock x:Name="CloudRedirectPatchDescriptionText"
                           Text="{res:Loc Setup_CloudRedirectPatchDescription}"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />

                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{res:Loc Setup_PatchStatus}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="PatchStatusText"
                                       Text="{res:Loc Setup_NotChecked}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:SymbolIcon Symbol="Wrench24" FontSize="24" />
                </ui:CardControl>

                <WrapPanel Margin="0,0,0,24">
                    <ui:Button x:Name="PatchButton"
                               Content="{res:Loc Setup_ApplyPatch}"
                               Icon="{ui:SymbolIcon Wrench24}"
                               Appearance="Primary"
                               Margin="0,0,8,0"
                               Click="Patch_Click" />
                    <ui:Button x:Name="PatchRevertButton"
                               Content="{res:Loc Setup_RevertPatch}"
                               Icon="{ui:SymbolIcon ArrowUndo24}"
                               Margin="0,0,8,0"
                               Visibility="Collapsed"
                               Click="PatchRevert_Click" />
                </WrapPanel>

                </StackPanel>
                <!-- End ST-only sections -->

                <TextBlock Text="{res:Loc Setup_DeployHeader}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{res:Loc Setup_DeployDescription}"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />

                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{res:Loc Setup_DllStatus}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="DeployStatusText"
                                       Text="{res:Loc Setup_NotChecked}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:SymbolIcon Symbol="PlugConnected24" FontSize="24" />
                </ui:CardControl>

                <WrapPanel Margin="0,0,0,24">
                    <ui:Button x:Name="DeployButton"
                               Content="{res:Loc Setup_DeployDll}"
                               Icon="{ui:SymbolIcon ArrowDownload24}"
                               Appearance="Primary"
                               Margin="0,0,8,0"
                               Click="Deploy_Click" />
                    <ui:Button x:Name="UninstallDllButton"
                               Content="{res:Loc Setup_UninstallDll}"
                               Icon="{ui:SymbolIcon Delete24}"
                               Margin="0,0,8,0"
                               Visibility="Collapsed"
                               Click="UninstallDll_Click" />
                </WrapPanel>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
